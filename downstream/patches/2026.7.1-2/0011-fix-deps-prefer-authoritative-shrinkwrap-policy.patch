From 9a7ded2d57ac2d19475eee7538b07168f7e8376d Mon Sep 17 00:00:00 2001
From: OpenClaw <openclaw@ashleyhollis.com>
Date: Sun, 19 Jul 2026 17:32:40 +1000
Subject: [PATCH] fix(deps): prefer authoritative shrinkwrap policy

---
 npm-shrinkwrap.json                          |  4 ++--
 scripts/generate-npm-shrinkwrap.mjs          | 20 ++++++++++++-----
 test/scripts/generate-npm-shrinkwrap.test.ts | 23 ++++++++++++++++++++
 3 files changed, 39 insertions(+), 8 deletions(-)

diff --git a/npm-shrinkwrap.json b/npm-shrinkwrap.json
index 552cd432fd..720706c69e 100644
--- a/npm-shrinkwrap.json
+++ b/npm-shrinkwrap.json
@@ -1,12 +1,12 @@
 {
   "name": "openclaw",
-  "version": "2026.7.1-1",
+  "version": "2026.7.1",
   "lockfileVersion": 3,
   "requires": true,
   "packages": {
     "": {
       "name": "openclaw",
-      "version": "2026.7.1-1",
+      "version": "2026.7.1",
       "hasInstallScript": true,
       "license": "MIT",
       "dependencies": {
diff --git a/scripts/generate-npm-shrinkwrap.mjs b/scripts/generate-npm-shrinkwrap.mjs
index 2e766646c9..ec60845a47 100644
--- a/scripts/generate-npm-shrinkwrap.mjs
+++ b/scripts/generate-npm-shrinkwrap.mjs
@@ -312,7 +312,7 @@ function readPnpmLockScopedVersionOverrides() {
   }
   return expandScopedOverrideChildren(overrides);
 }
-function mergeOverrideEntry(merged, name, spec) {
+function mergeOverrideEntry(merged, name, spec, options = {}, path = name) {
   const current = merged[name];
   if (current === undefined) {
     merged[name] = spec;
@@ -320,7 +320,7 @@ function mergeOverrideEntry(merged, name, spec) {
   }
   if (isPlainObject(current) && isPlainObject(spec)) {
     for (const [nestedName, nestedSpec] of Object.entries(spec)) {
-      mergeOverrideEntry(current, nestedName, nestedSpec);
+      mergeOverrideEntry(current, nestedName, nestedSpec, options, `${path}>${nestedName}`);
     }
     return;
   }
@@ -335,7 +335,7 @@ function mergeOverrideEntry(merged, name, spec) {
       if (nestedName === ".") {
         continue;
       }
-      mergeOverrideEntry(merged[name], nestedName, nestedSpec);
+      mergeOverrideEntry(merged[name], nestedName, nestedSpec, options, `${path}>${nestedName}`);
     }
     return;
   }
@@ -349,7 +349,14 @@ function mergeOverrideEntry(merged, name, spec) {
     return;
   }
   if (JSON.stringify(current) !== JSON.stringify(spec)) {
-    throw new Error(`package.json overrides.${name} conflicts with pnpm lock policy for ${name}`);
+    if (options.preferIncoming === true) {
+      merged[name] = spec;
+      return;
+    }
+    throw new Error(
+      `package.json overrides.${path} conflicts with pnpm lock policy: ` +
+        `${JSON.stringify(current)} !== ${JSON.stringify(spec)}`,
+    );
   }
 }
 
@@ -378,13 +385,13 @@ function parseNpmAliasOverrideSpec(spec) {
   return { name: spec.slice("npm:".length, versionIndex) };
 }
 
-function mergeOverrides(packageOverrides, workspaceOverrides, pnpmLockOverrides) {
+function mergeOverrides(packageOverrides, workspaceOverrides, pnpmLockOverrides, options = {}) {
   const merged = normalizeOverrides(packageOverrides);
   for (const [name, spec] of [
     ...Object.entries(workspaceOverrides),
     ...Object.entries(pnpmLockOverrides),
   ]) {
-    mergeOverrideEntry(merged, name, spec);
+    mergeOverrideEntry(merged, name, spec, options);
   }
   return Object.keys(merged).length > 0 ? merged : undefined;
 }
@@ -739,6 +746,7 @@ function generateShrinkwrap(packageDir, options = {}) {
         : {},
       readShrinkwrapOverrides(),
       {},
+      { preferIncoming: true },
     );
     const peerResolutionArgs = shouldUseLegacyPeerDepsForShrinkwrap(packageJson)
       ? ["--legacy-peer-deps"]
diff --git a/test/scripts/generate-npm-shrinkwrap.test.ts b/test/scripts/generate-npm-shrinkwrap.test.ts
index ea6e1cc63c..5c95953638 100644
--- a/test/scripts/generate-npm-shrinkwrap.test.ts
+++ b/test/scripts/generate-npm-shrinkwrap.test.ts
@@ -11,6 +11,7 @@ import {
   disableShrinkwrappedOverrideConflictSources,
   exactOverrideRulesFromOverrides,
   exactVersionFromOverrideSpec,
+  mergeOverrides,
   normalizeOverrides,
   normalizeNpmVersionDrift,
   packageJsonForShrinkwrap,
@@ -91,6 +92,28 @@ describe("generate-npm-shrinkwrap", () => {
     });
   });
 
+  it("prefers authoritative lock policy over stale shrinkwrap stabilization hints", () => {
+    const current = {
+      ora: {
+        ".": "9.4.1",
+        "string-width": { ".": "8.2.1", "strip-ansi": { ".": "6.0.1" } },
+      },
+    };
+    const authoritative = {
+      ora: {
+        ".": "9.4.1",
+        "string-width": { ".": "8.2.1", "strip-ansi": { ".": "7.2.0" } },
+      },
+    };
+
+    expect(() => mergeOverrides(current, authoritative, {})).toThrow(
+      "overrides.ora>string-width>strip-ansi>. conflicts",
+    );
+    expect(mergeOverrides(current, authoritative, {}, { preferIncoming: true })).toEqual(
+      authoritative,
+    );
+  });
+
   it("rejects short flag package selectors before resolving shrinkwrap targets", () => {
     expect(() => resolvePackageDirs(["--package-dir", "-h"])).toThrow(
       "--package-dir requires a package directory.",
-- 
2.43.0

